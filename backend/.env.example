# 复制本文件为 backend/.env 后填写真实值（.env 已加入 .gitignore，勿提交仓库）
# 密钥在火山控制台：右上角账号 → 访问密钥（或 访问控制 IAM）

# ---------- 火山 TOS（服务端上传）----------
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_REGION=cn-guangzhou
TOS_ENDPOINT=https://tos-cn-guangzhou.volces.com
TOS_BUCKET=wanx-ai
# 可选：桶自定义域名或固定公网根（不填则按 https://{bucket}.tos-{region}.volces.com 拼直链；公有读桶可直接访问该 URL）
# TOS_PUBLIC_BASE_URL=https://wanx-ai.tos-cn-guangzhou.volces.com
#
# 若浏览器控制台对 TOS 直链报 CORS（fetch 被拦、但 img/video 能显示）：须在 TOS 控制台为本桶配置「跨域访问」
#（来源含 http://localhost:5173 与线上 https 域名；Methods: GET、HEAD）。详见仓库《部署文档》「TOS 跨域」小节。

# Seedance / 方舟返回的成片外链往往有时效；任务成功时由服务端下载并写入本桶，再把 result_url 换成 TOS 直链（须已配置上方 TOS）
# VIDEO_RESULT_MIRROR_TOS=0
# VIDEO_TOS_MIRROR_MAX_MB=600
# VIDEO_TOS_MIRROR_TIMEOUT_MS=300000

# 可选
# MAX_UPLOAD_MB=512
# STORAGE_UPLOAD_RATE_PER_MIN=60

# ---------- 方舟 Seedance / 视频生成（创意画布、POST /admin-api/video/jobs）----------
# 与 TOS 的访问密钥不是同一个：请到「火山方舟」控制台创建 API Key，填在下面任一项即可
# https://console.volcengine.com/ark （或控制台搜索「方舟」）
ARK_API_KEY=
# 若更愿意用这个变量名也可以，二选一：
# SEEDANCE_API_KEY=
# 接入点非北京时按需改（默认北京方舟 OpenAPI）
# ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
#
# 视频 content 策略（与「创建视频生成任务」同一接口；不设环境变量时即为 reference_only，适配 Seedance 2.0 多模态参考）：
# - reference_only（默认）：不走 first_frame/last_frame；参考视频带 role=reference_video，图+视频时参考图带 role=reference_image（见 seedanceClient.js）。
# - auto：仅「1～2 张图且无参考视频」时使用首尾帧 role；经典图生视频/首尾帧专用。
# ARK_VIDEO_CONTENT_MODE=reference_only
# ARK_VIDEO_CONTENT_MODE=auto
#
# 同一次请求里既有参考图又有参考视频时，可选：强制用下方接入点调方舟（须为控制台支持该组合的 Seedance 2.0 ep；不设置则用「视频模型配置」里选中项的 api_model_id）
# ARK_MULTIMODAL_MODEL_ID=ep-xxxx
#
# 参考素材数量上限（默认按 2.0 宣传约 9 图 / 3 视频；若接入点是 1.x / Lite 请改小，以控制台模型说明为准）
# ARK_VIDEO_MAX_REF_IMAGES=9
# ARK_VIDEO_MAX_REF_VIDEOS=3
