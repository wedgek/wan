{
  "name": "wan-ai",
  "private": true,
  "version": "0.0.0",
  "description": "万相中台：frontend（Vue3+Vite）+ backend（Express+SQLite），根目录一条命令装齐依赖",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "npm install",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run server:dev\" \"node scripts/wait-backend-dev.cjs && npm run dev:fe\"",
    "dev:fe": "npm run dev -w frontend",
    "server:dev": "npm run dev -w backend",
    "dev:all": "npm run dev",
    "dev:prod": "npm run dev:prod -w frontend",
    "build:test": "npm run build:test -w frontend",
    "build:prod": "npm run build:prod -w frontend",
    "start:prod": "npm run start -w backend",
    "db:patch": "npm run db:patch -w backend",
    "analyze": "npm run analyze -w frontend",
    "preview": "npm run preview -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
